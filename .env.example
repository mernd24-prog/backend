NODE_ENV=production
PRODUCTION=true
PORT=4000
APP_NAME=sam-global-ecommerce
API_PREFIX=/api/v1
PUBLIC_API_BASE_URL=https://<API_DOMAIN>

CORS_ORIGIN=https://<CUSTOMER_DOMAIN>,https://www.<CUSTOMER_DOMAIN>,https://<ADMIN_DOMAIN>,https://<SELLER_DOMAIN>
SOCKET_CORS_ORIGIN=https://<CUSTOMER_DOMAIN>,https://www.<CUSTOMER_DOMAIN>,https://<ADMIN_DOMAIN>,https://<SELLER_DOMAIN>

MONGO_URI=mongodb://ecommerce_app:<MONGO_APP_PASSWORD>@127.0.0.1:27017/ecommerce?authSource=ecommerce
POSTGRES_URL=postgresql://ecommerce_app:<POSTGRES_APP_PASSWORD>@127.0.0.1:5432/ecommerce
REDIS_URL=redis://:<REDIS_PASSWORD>@127.0.0.1:6379/0
ELASTICSEARCH_NODE=http://127.0.0.1:9200
ENABLE_ELASTICSEARCH=true

JWT_ACCESS_SECRET=<JWT_ACCESS_SECRET>
JWT_REFRESH_SECRET=<JWT_REFRESH_SECRET>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

BUSINESS_STATE=KARNATAKA
GSTIN_MARKETPLACE=
REFERRAL_REFERRER_BONUS=100
REFERRAL_REFEREE_BONUS=50
MAX_WALLET_USAGE_PER_ORDER_PERCENT=30

EMAIL_HOST=<SMTP_HOST>
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=<SMTP_USER>
EMAIL_PASS=<SMTP_PASSWORD>
EMAIL_FROM=no-reply@<CUSTOMER_DOMAIN>
DEFAULT_FROM_EMAIL=no-reply@<CUSTOMER_DOMAIN>
ENABLE_LIVE_EMAIL=true
ENABLE_EMAIL_MOCK=false

CLOUDINARY_CLOUD_NAME=<CLOUDINARY_NAME>
CLOUDINARY_API_KEY=<CLOUDINARY_KEY>
CLOUDINARY_API_SECRET=<CLOUDINARY_SECRET>
ENABLE_CLOUDINARY=true
ENABLE_LOCAL_UPLOAD_STORAGE=false

GOOGLE_CLIENT_IDS=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
ENABLE_LIVE_SOCIAL_AUTH=true
ENABLE_STATIC_SOCIAL_AUTH=false

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
ENABLE_LIVE_RAZORPAY=true
ENABLE_RAZORPAY_MOCK=false
RAZORPAY_MOCK_AUTO_CAPTURE=true

JSON_BODY_LIMIT=50mb
MAX_DOCUMENT_UPLOAD_BYTES=52428800
ENABLE_CRON=true

# Do not enable static OTP in production unless there is a planned temporary support reason.
# STATIC_OTP=
ENABLE_LIVE_OTP=true
ENABLE_STATIC_OTP=false
EXPOSE_STATIC_OTP=false

# Testing/staging without third-party services:
# PRODUCTION=false
# ENABLE_LIVE_EMAIL=false
# ENABLE_EMAIL_MOCK=true
# ENABLE_LIVE_OTP=false
# ENABLE_STATIC_OTP=true
# EXPOSE_STATIC_OTP=true
# ENABLE_ELASTICSEARCH=false
# ENABLE_LIVE_RAZORPAY=false
# ENABLE_RAZORPAY_MOCK=true
# ENABLE_CLOUDINARY=false
# ENABLE_LOCAL_UPLOAD_STORAGE=true
# ENABLE_LIVE_SOCIAL_AUTH=false
# ENABLE_STATIC_SOCIAL_AUTH=true
