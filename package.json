{
  "name": "ecommerce-backend",
  "version": "1.0.0",
  "description": "Production-grade modular monolith e-commerce backend ready for future microservice extraction.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "node --check src/server.js",
    "db:migrate": "node scripts/db/run-sequelize-migrations.js",
    "db:migrate:undo": "node scripts/db/rollback-sequelize-migration.js",
    "db:seed:seller-finance": "node scripts/db/seed-seller-finance-demo.js",
    "db:seed:commerce": "node scripts/db/seed-commerce-demo.js --reset",
    "db:seed:commerce:append": "node scripts/db/seed-commerce-demo.js",
    "db:seed:commerce:qa": "node scripts/db/seed-commerce-qa.js --reset",
    "db:setup": "npm run db:migrate && npm run db:seed:commerce",
    "db:create-super-admin": "node scripts/db/create-super-admin.js",
    "db:seed:rbac": "node scripts/db/seed-rbac.js",
    "db:sync:role-permissions": "node scripts/db/sync-default-role-permissions.js",
    "postman:sync": "node scripts/postman/sync-postman-collection.js",
    "seed:all": "node scripts/seed/master-seed.js all --reset",
    "seed:all:append": "node scripts/seed/master-seed.js all",
    "seed:locations": "node scripts/seed/master-seed.js locations --reset",
    "seed:categories": "node scripts/seed/master-seed.js categories --reset",
    "seed:brands": "node scripts/seed/master-seed.js brands --reset",
    "seed:sellers": "node scripts/seed/master-seed.js sellers --reset",
    "seed:warehouses": "node scripts/seed/master-seed.js warehouses --reset",
    "seed:products": "node scripts/seed/master-seed.js products --reset",
    "seed:customers": "node scripts/seed/master-seed.js customers --reset",
    "seed:orders": "node scripts/seed/master-seed.js orders --reset",
    "seed:reviews": "node scripts/seed/master-seed.js reviews --reset",
    "seed:inventory": "node scripts/seed/master-seed.js inventory --reset",
    "seed:gst": "node scripts/seed/master-seed.js gst --reset",
    "seed:attributes": "node scripts/seed/master-seed.js attributes --reset",
    "seed:options": "node scripts/seed/master-seed.js options --reset",
    "seed:countries": "node scripts/seed/master-seed.js countries --reset",
    "seed:hsn": "node scripts/seed/master-seed.js hsn --reset",
    "seed:tax-classes": "node scripts/seed/master-seed.js tax-classes --reset",
    "seed:families": "node scripts/seed/master-seed.js families --reset",
    "seed:commissions": "node scripts/seed/master-seed.js commissions --reset",
    "seed:platform-fees": "node scripts/seed/master-seed.js platform-fees --reset",
    "seed:badges": "node scripts/seed/master-seed.js badges --reset",
    "seed:tags": "node scripts/seed/master-seed.js tags --reset",
    "seed:collections": "node scripts/seed/master-seed.js collections --reset",
    "seed:variants": "node scripts/seed/master-seed.js variants --reset",
    "seed:recommendations": "node scripts/seed/master-seed.js recommendations --reset",
    "seed:analytics": "node scripts/seed/master-seed.js analytics --reset",
    "seed:search": "node scripts/seed/master-seed.js search --reset",
    "seed:notifications": "node scripts/seed/master-seed.js notifications --reset",
    "seed:catalog": "node scripts/seed/master-seed.js countries --reset && node scripts/seed/master-seed.js locations && node scripts/seed/master-seed.js categories && node scripts/seed/master-seed.js brands && node scripts/seed/master-seed.js options && node scripts/seed/master-seed.js gst && node scripts/seed/master-seed.js hsn && node scripts/seed/master-seed.js tax-classes && node scripts/seed/master-seed.js attributes && node scripts/seed/master-seed.js families && node scripts/seed/master-seed.js commissions && node scripts/seed/master-seed.js platform-fees && node scripts/seed/master-seed.js badges && node scripts/seed/master-seed.js tags && node scripts/seed/master-seed.js collections"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.15.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.16.0",
    "cloudinary": "^2.3.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^12.7.0",
    "google-auth-library": "^9.14.2",
    "handlebars": "^4.7.8",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.2.9",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "objection": "^3.1.5",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "razorpay": "^2.9.6",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.2",
    "slugify": "^1.6.6",
    "@faker-js/faker": "^8.0.2",
    "socket.io": "^4.8.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.8.0",
    "nodemon": "^3.1.4",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.3.3"
  }
}
