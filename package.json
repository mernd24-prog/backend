{
  "name": "ecommerce-backend",
  "version": "1.0.0",
  "description": "Production-grade modular monolith e-commerce backend ready for future microservice extraction.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "node --check src/server.js",
    "db:migrate": "node scripts/db/run-sequelize-migrations.js",
    "db:migrate:undo": "node scripts/db/rollback-sequelize-migration.js",
    "db:setup": "npm run db:migrate && npm run db:seed:rbac && npm run db:seed:commerce",
    "db:create-super-admin": "node scripts/db/create-super-admin.js",
    "db:seed:rbac": "node scripts/db/seed-rbac.js",
    "db:repair:rbac-role-assignments": "node scripts/db/repair-rbac-role-assignments.js",
    "db:backfill:shipments": "node scripts/db/backfill-missing-order-shipments.js",
    "db:backfill:organizations": "node scripts/db/backfill-organization-ownership.js",
    "db:update-super-admin": "node scripts/db/update-super-admin.js",
    "db:reset": "node scripts/db/reset-all-databases.js",
    "postman:sync": "node scripts/postman/sync-postman-collection.js",
    "seed:all": "node scripts/seed/master-seed.js all --reset && npm run db:repair:rbac-role-assignments",
    "seed:all:append": "node scripts/seed/master-seed.js all && npm run db:repair:rbac-role-assignments",
    "seed:locations": "node scripts/seed/master-seed.js locations",
    "seed:categories": "node scripts/seed/master-seed.js categories",
    "seed:brands": "node scripts/seed/master-seed.js brands",
    "seed:sellers": "node scripts/seed/master-seed.js sellers && npm run db:repair:rbac-role-assignments -- --roles=seller,seller-admin,seller-sub-admin",
    "seed:warehouses": "node scripts/seed/master-seed.js warehouses",
    "seed:products": "node scripts/seed/master-seed.js products",
    "seed:customers": "node scripts/seed/master-seed.js customers",
    "seed:orders": "node scripts/seed/master-seed.js orders",
    "seed:reviews": "node scripts/seed/master-seed.js reviews",
    "seed:inventory": "node scripts/seed/master-seed.js inventory",
    "seed:gst": "node scripts/seed/master-seed.js gst",
    "seed:attributes": "node scripts/seed/master-seed.js attributes",
    "seed:options": "node scripts/seed/master-seed.js options",
    "seed:countries": "node scripts/seed/master-seed.js countries",
    "seed:hsn": "node scripts/seed/master-seed.js hsn",
    "seed:tax-classes": "node scripts/seed/master-seed.js tax-classes",
    "seed:families": "node scripts/seed/master-seed.js families",
    "seed:commissions": "node scripts/seed/master-seed.js commissions",
    "seed:platform-fees": "node scripts/seed/master-seed.js platform-fees",
    "seed:badges": "node scripts/seed/master-seed.js badges",
    "seed:tags": "node scripts/seed/master-seed.js tags",
    "seed:collections": "node scripts/seed/master-seed.js collections",
    "seed:variants": "node scripts/seed/master-seed.js variants",
    "seed:recommendations": "node scripts/seed/master-seed.js recommendations",
    "seed:analytics": "node scripts/seed/master-seed.js analytics",
    "seed:search": "node scripts/seed/master-seed.js search",
    "seed:notifications": "node scripts/seed/master-seed.js notifications",
    "db:seed:commerce": "npm run seed:all",
    "db:seed:commerce:append": "npm run seed:all:append",
    "seed:catalog": "node scripts/seed/master-seed.js catalog"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.15.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.16.0",
    "cloudinary": "^2.3.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^12.7.0",
    "google-auth-library": "^9.14.2",
    "handlebars": "^4.7.8",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.2.9",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "objection": "^3.1.5",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "razorpay": "^2.9.6",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.2",
    "slugify": "^1.6.6",
    "@faker-js/faker": "^8.0.2",
    "socket.io": "^4.8.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.8.0",
    "nodemon": "^3.1.4",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.3.3"
  }
}
